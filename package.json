{
	"name": "clickmake",
	"displayName": "clickmake",
	"description": "Run makefiles from within the editor by clicking on target",
	"version": "0.4.3",
	"license": "MIT",
	"icon": "media/icon.png",
	"publisher": "eddie2072",
	"repository": {
		"type": "git",
		"url": "https://github.com/wangduanduan/vscode-clickmake"
	},
	"engines": {
		"vscode": "^1.65.0"
	},
	"categories": [
		"Programming Languages",
		"Debuggers",
		"Other"
	],
	"keywords": [
		"C",
		"C++",
		"Makefile"
	],
	"activationEvents": [
		"onCommand:clickmake.enableCodeLens",
		"onLanguage:makefile"
	],
	"main": "./out/main.js",
	"contributes": {
		"commands": [
			{
				"title": "Enable Makefile CodeLens",
				"command": "clickmake.enableCodeLens"
			},
			{
				"title": "Disable Makefile Codelens",
				"command": "clickmake.disableCodeLens"
			},
			{
				"title": "Run target again (or do nothing)",
				"command": "clickmake.runAgain"
			}
		],
		"configuration": {
			"properties": {
				"clickmake.enabled": {
					"type": "boolean",
					"default": true,
					"description": "enable or disable the processing of make files"
				},
				"clickmake.parser": {
					"type": "string",
					"enum": [
						"split",
						"fsm"
					],
					"enumDescriptions": [
						"Simple line-split parser (default). Readable and fast enough for normal Makefiles.",
						"Single-pass scanner. ~3x faster on very large files, identical output."
					],
					"default": "split",
					"description": "Which Makefile parsing implementation to use."
				}
			}
		},
		"keybindings": [
			{
				"command": "clickmake.runAgain",
				"key": "Ctrl+Shift+x",
				"mac": "Ctrl+Shift+x"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "bun build ./src/extension.ts --outdir ./out --entry-naming main.js --external vscode --format=cjs --target=node --minify",
		"bundle": "bun build ./src/extension.ts --outdir ./out --entry-naming main.js --external vscode --format=cjs --target=node --sourcemap=linked",
		"bundle-watch": "bun build ./src/extension.ts --outdir ./out --entry-naming main.js --external vscode --format=cjs --target=node --sourcemap=linked --watch",
		"test-compile": "tsc -p ./",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile",
		"test": "node ./out/test/runTest.js",
		"test:unit": "npm run compile && mocha --ui tdd out/MakefileParser.test.js",
		"bench": "bun run src/MakefileParser.bench.ts",
		"package": "vsce package --no-dependencies",
		"publish": "vsce publish --no-dependencies"
	},
	"devDependencies": {
		"@types/mocha": "^10.0.0",
		"@types/node": "^20.0.0",
		"@types/vscode": "^1.65.0",
		"@vscode/test-electron": "^2.1.2",
		"@vscode/vsce": "^3.9.1",
		"glob": "^11.0.0",
		"mocha": "^11.0.0",
		"typescript": "^5.9.0"
	}
}
